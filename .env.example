# Flori AI — 환경 변수 예시. 실제 값은 .env 에 두고 깃에 올리지 않는다.

# LLM (LiteLLM 프록시 경유 → Bedrock Claude Haiku 4.5)
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=
LLM_MODEL=claude-haiku-4-5

# 백엔드 (Spring REST — 도구 대상)
BACKEND_BASE_URL=http://localhost:8080

# Redis (세션 · 사용량 캡)
REDIS_URL=redis://localhost:6379/0

# 인증 / 캡 / 타임아웃 / 세션
ME_CACHE_TTL_SECONDS=60
REQUEST_TIMEOUT_SECONDS=30
USAGE_CAP_PER_DAY=500
SESSION_TTL_SECONDS=86400

# LiteLLM 컨테이너용 master key (로컬은 비워둠)
LITELLM_MASTER_KEY=

# AWS Bedrock 자격 — LiteLLM이 사용. env로만 주입, 코드/깃 금지.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
